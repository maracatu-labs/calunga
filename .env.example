# Deployment environment ("development" or "production").
# In "production", APP refuses to start with default/weak JWT_SECRET.
APP_ENV=development

# Public host routed by Traefik. In production: maracatu.org.
CALUNGA_HOST=localhost

# Database
POSTGRES_DB=maracatu
POSTGRES_USER=maracatu
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://maracatu:changeme@db:5432/maracatu

# Cache
REDIS_URL=redis://redis:6379/0

# External APIs
CAMARA_API_URL=https://dadosabertos.camara.leg.br/api/v2
TRANSPARENCIA_API_TOKEN=

# Gemini
GOOGLE_API_KEY=
DEFAULT_MODEL=gemini-2.5-flash

# Auth (JWT + magic link)
# In production generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
MAGIC_LINK_TTL_MINUTES=15
APP_URL=http://localhost:3000

# Email (Resend). Domain must be verified at https://resend.com/domains.
RESEND_API_KEY=
EMAIL_FROM=Maracatu <noreply@maracatu.org>

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Rate limits on /v1/auth/magic-link (fail-open on Redis errors)
MAGIC_LINK_EMAIL_LIMIT_HOUR=3
MAGIC_LINK_IP_LIMIT_HOUR=10

# Daily Gemini token quota per authenticated user
TOKEN_QUOTA_DAILY_INPUT=200000
TOKEN_QUOTA_DAILY_OUTPUT=50000

# Per-message and per-request hard limits (HTTP 413 when exceeded)
MAX_USER_MESSAGE_CHARS=8000
MAX_REQUEST_CHARS=60000

# Sentry — leave empty to disable error capture
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN_WEB=

# Cortejo (frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000
COOKIE_SECURE=false

# Postgres backup to Cloudflare R2 (eeshugerman/postgres-backup-s3)
# Leave R2_ACCESS_KEY_ID empty to disable the pg-backup service.
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=7
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=maracatu-backups
R2_ENDPOINT=
